# Required for the current default sched-claw profile (OpenAI / gpt-5.4).
OPENAI_API_KEY=replace-me

# Optional OpenAI-compatible gateway or proxy override.
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional extra skill roots loaded in addition to builtin sched-claw skills.
# NANOCLAW_CORE_SKILL_ROOTS=.codex/skills

# Optional web_search hosted backend selection. Leave unset to use the local default.
# NANOCLAW_CORE_WEB_SEARCH_BACKEND=tavily_api
# TAVILY_API_KEY=replace-me
# NANOCLAW_CORE_WEB_SEARCH_EXA_API_KEY=replace-me
# FIRECRAWL_API_KEY=replace-me

# Optional tracing for the sched-claw client and daemon.
# RUST_LOG=warn

# Note: the root daemon path does not require extra env here. Use
# apps/sched-claw/scripts/start-root-daemon.sh to launch it with the correct
# client uid/gid handoff automatically.
