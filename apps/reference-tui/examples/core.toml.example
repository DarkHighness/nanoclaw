global_system_prompt = "You are operating inside the current workspace."

skill_roots = [
  ".nanoclaw/skills",
]

[host]
workspace_only = true
sandbox_fail_if_unavailable = false
store_dir = ".nanoclaw/store"
# Optional host-runtime caps for local CPU usage.
# tokio_worker_threads = 2
# tokio_max_blocking_threads = 8

[models.gpt_5_4_default]
provider = "openai"
model = "gpt-5.4"
context_window_tokens = 400000
max_output_tokens = 128000
compact_trigger_tokens = 320000
temperature = 0.2
reasoning_effort = "medium"
capabilities = { tool_calls = true, vision = true, image_generation = true, audio_input = false, tts = true }
additional_params = { metadata = { tier = "standard" } }

[agents.primary]
model = "gpt_5_4_default"
sandbox = "workspace_write"
auto_compact = true

[agents.subagent_defaults]
model = "gpt_5_4_default"
sandbox = "read_only"
reasoning_effort = "medium"
auto_compact = true

[internal.summary]
model = "gpt_5_4_default"
reasoning_effort = "low"
max_output_tokens = 32000

[internal.memory]
model = "gpt_5_4_default"
reasoning_effort = "medium"
max_output_tokens = 32000

[hook_env]
PROJECT_NAME = "nanoclaw"

[[mcp_servers]]
name = "filesystem"
transport = "stdio"
command = "uvx"
args = ["mcp-server-filesystem", "."]
cwd = "."

[[mcp_servers]]
name = "remote-docs"
transport = "streamable_http"
url = "http://localhost:8000/mcp"

[mcp_servers.headers]
Authorization = "Bearer replace-me"
