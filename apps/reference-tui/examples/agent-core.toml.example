system_prompt = "You are operating inside the current workspace."

skill_roots = [
  ".agent-core/skills",
]

[provider]
kind = "openai"
model = "gpt-4.1-mini"
temperature = 0.2
max_tokens = 4096
additional_params = { metadata = { tier = "standard" } }

[runtime]
workspace_only = true
sandbox_fail_if_unavailable = false
auto_compact = true
context_tokens = 128000
compact_trigger_tokens = 96000
compact_preserve_recent_messages = 8
store_dir = ".agent-core/store"

[tui]
command_prefix = "/"

[hook_env]
PROJECT_NAME = "nanoclaw"

[[mcp_servers]]
name = "filesystem"
transport = "stdio"
command = "uvx"
args = ["mcp-server-filesystem", "."]
cwd = "."

[[mcp_servers]]
name = "remote-docs"
transport = "streamable_http"
url = "http://localhost:8000/mcp"

[mcp_servers.headers]
Authorization = "Bearer replace-me"
