#!/bin/sh
set -eu

message_file=$1
first_line=$(sed -n '1p' "$message_file" | tr -d '\r')

case "$first_line" in
    Merge\ *|Revert\ *)
        exit 0
        ;;
esac

pattern='^(build|chore|ci|docs|feat|fix|perf|refactor|revert|style|test)(\([a-z0-9._/-]+\))?(!)?: .+$'

if printf '%s\n' "$first_line" | grep -Eq "$pattern"; then
    exit 0
fi

cat >&2 <<'EOF'
commit-msg: first line must follow Conventional Commits.
Expected format: type(scope): subject
Examples:
  feat(runtime): add loop detection
  docs: document git hook installation
  refactor!: drop legacy config surface
EOF
exit 1

